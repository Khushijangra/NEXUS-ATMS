# Normalize line endings for text files
* text=auto eol=lf

# Keep Windows scripts with CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.pt binary
*.pth binary
*.pkl binary
*.npz binary
*.onnx binary
*.tflite binary
*.mp3 binary
*.wav binary
*.ico binary
